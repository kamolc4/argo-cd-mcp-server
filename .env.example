# ─────────────────────────────────────────────────────────
# Argo CD MCP Server — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────

# TCP port the Express server listens on
PORT=3000

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Node environment: development | production
NODE_ENV=production

# ─── MCP Authentication ───────────────────────────────────
# Secret API key that MCP clients must send as:
#   Authorization: Bearer <MCP_API_KEY>
# Generate with: openssl rand -hex 32
MCP_API_KEY=change-me-to-a-strong-random-secret-32-chars

# ─── Argo CD Connection ───────────────────────────────────
# Full base URL of your Argo CD server (no trailing slash)
ARGOCD_SERVER_URL=https://argocd.example.com

# Argo CD API token for the dedicated mcp-server service account
# Generate with: argocd account generate-token --account mcp-server
# NEVER share or log this value.
ARGOCD_TOKEN=your-argocd-api-token-here

# Set to true ONLY for development with self-signed TLS certificates.
# Must be false in production.
ARGOCD_INSECURE_TLS=false

# Default Argo CD namespace (used in health checks)
ARGOCD_NAMESPACE=argocd

# ─── Rate Limiting ────────────────────────────────────────
# Time window for rate limiting in milliseconds (default: 60 seconds)
RATE_LIMIT_WINDOW_MS=60000

# Maximum number of requests per window per IP
RATE_LIMIT_MAX=60

# ─── Tool Feature Flags ───────────────────────────────────
# Set to true to enable the sync_application write tool.
# Review security implications before enabling in production.
# See README — Security Notes section.
ENABLE_SYNC_TOOL=false
